# Copy to .env.local and fill in. NEVER commit .env.local (gitignored).
# In production, set the same variables in the Vercel project (Production + Preview).

# --- Turso / libSQL database ---
# Local dev: a plain file URL, e.g. file:./data/dev.db
# Production: your Turso database URL, e.g. libsql://<db>-<org>.turso.io
TURSO_DATABASE_URL=

# Auth token for the hosted Turso DB (leave blank for a local file: URL).
TURSO_AUTH_TOKEN=

# --- Clerk authentication (values from the Clerk dashboard) ---
# Use a Clerk *development* instance for local dev, *production* instance in prod.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
